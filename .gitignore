# =============================================================================
# olt — .gitignore
# =============================================================================

# ── Binaries (committed per-platform in artifacts/<platform>/) ────────────────
# Root-level strays (leading / anchors to repo root only)
/odin-lint
/olt

# Old flat artifact names (replaced by platform subfolders).
# Use exact paths so platform subfolders like artifacts/macos-arm64/olt are NOT ignored.
/artifacts/odin-lint
/artifacts/odin-lint-mcp
/artifacts/odin-lint-lsp
/artifacts/odin-lint-plugin.dylib
/artifacts/odin-lint-plugin.so
/artifacts/odin-lint-debug
/artifacts/odin-lint-debug2
/artifacts/odin-lint-debug.dSYM/
/artifacts/odin-lint-debug2.dSYM/
/artifacts/olt
/artifacts/olt-mcp
/artifacts/olt-lsp

# ── Generated code graph ──────────────────────────────────────────────────────
.codegraph/

# ── Test results (generated, not source) ─────────────────────────────────────
test_results/

# ── RuiShin test results (internal project, not for public repo) ─────────────
test_results/ruishin/
test_results/ruishin_*/
test_results/ruishin*.md
test_results/ruishin*.txt
test_results/generic_report_*.md
test_results/all_libraries/
test_results/FINAL_COMPREHENSIVE_REPORT_*.md

# ── Developer notes (not for public repo) ────────────────────────────────────
CLAUDE.md
SKILL.md
agents.md
plans/

# ── macOS metadata ────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Python cache ─────────────────────────────────────────────────────────────
scripts/__pycache__/
**/__pycache__/
*.pyc
